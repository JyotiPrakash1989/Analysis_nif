# mStock API (Type B) - copy to .env and set your values. Never commit .env.
# Example: MSTOCK_API_KEY=IHT8r8A6aHoP0j4k71JuQEJfDlXLMoPk/PFOERNeT1k=
#          MSTOCK_APP_NAME=JPAPP
MSTOCK_API_KEY=your_api_key_here
MSTOCK_APP_NAME=JPAPP
# Session JWT (access_token) — POST https://api.mstock.trade/openapi/typea/session/token
# Body: api_key, request_token (SMS OTP), checksum (usually L). Valid until midnight.
# Easiest: cd stat_react && npm run mstock:token
# MSTOCK_JWT_TOKEN=eyJhbGciOiJIUzI1NiIs...   (also used for wss://wsbcastxoi.mstock.com/ws?token=…)
# MSTOCK_WS_URL=wss://wsbcastxoi.mstock.com/ws?token=YOUR_JWT
# MSTOCK_OTP=123456
# MSTOCK_CHECKSUM=L
# MSTOCK_TOTP_SECRET=base32_secret_from_mstock_totp_setup
# NIFTY historical/quote tokens (annexure: NIFTY50=26000). Only change if mStock updates tokens.
# MSTOCK_NIFTY_HIST_TOKEN=26000,99926000,999260

# Auto TOTP login (app creates JWT on launch — no manual npm run needed):
MSTOCK_TOTP_SECRET=base32_secret_from_mstock_totp_setup
# Optional SMS fallback (or one-shot OTP in .env):
# MSTOCK_USERNAME=your_client_id
# MSTOCK_PASSWORD=your_password
# MSTOCK_OTP=123456
# MSTOCK_JWT_TOKEN=eyJ...   (optional; app overwrites via auto-login)

# Mobile order routing — use your PC's LAN IP so orders go through stat_react
# (mStock whitelists your PC IP, not the phone). Phone and PC must be on same Wi‑Fi.
# Example: NIFTYOPTIMA_API=http://192.168.1.42:3200
# Run on PC: cd stat_react && npm run dev
# NIFTYOPTIMA_API=http://192.168.1.42:3200
