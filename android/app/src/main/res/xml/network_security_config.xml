<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP to local NiftyOptima server (NIFTYOPTIMA_API=http://192.168.x.x:3200). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
