# NiftyOptima backend (server/index.mjs) — never commit real secrets.
# Keys can be in repo root `Nif/.env` or this file; duplicate keys here override root.
NIFTYOPTIMA_PORT=3200
# NIFTYOPTIMA_STRICT_PORT=1 — exit if NIFTYOPTIMA_PORT is in use (default: try next ports for dev).
# NIFTYOPTIMA_PORT_FALLBACK_MAX=30 — max extra ports to try when not strict.
MSTOCK_API_KEY=

# Session JWT = access_token from POST https://api.mstock.trade/openapi/typea/session/token
# (api_key + MSTOCK_OTP as request_token + checksum). Valid until midnight.
# npm run mstock:token   — OTP only (after connect/login sent OTP)
# npm run mstock:login   — full login + OTP + session/token
# JWT for REST + broadcast WS (same token as trade.mstock.com / session/token access_token)
# Session JWT (required for Type B quote + 1m historical). Until midnight.
# npm run mstock:token   (SMS OTP)  OR  npm run mstock:totp  (only if TOTP enabled on trade.mstock.com)
# MSTOCK_JWT_TOKEN=
# MSTOCK_USE_TOTP=1      # auto refresh via MSTOCK_TOTP_SECRET — fails if TOTP not enabled on account
# Optional full URL (overrides build from JWT):
# MSTOCK_WS_URL=wss://wsbcastxoi.mstock.com/ws?token=YOUR_JWT
# MSTOCK_WS_BROADCAST_URL=wss://wsbcastxoi.mstock.com/ws
# MSTOCK_OTP=
# MSTOCK_CHECKSUM=L
# Default: OTP on first page load in UI (no TOTP auto). Optional server TOTP:
# MSTOCK_USE_TOTP=1
# MSTOCK_TOTP_SECRET=base32_from_portal
# MSTOCK_USERNAME=
# MSTOCK_PASSWORD=
# MSTOCK_USERNAME=
# MSTOCK_PASSWORD=

# When mStock returns no LTP (e.g. 401), use delayed public NIFTY (^NSEI via Yahoo) for headline/chain. Set 0 to disable.
# NIFTY_PUBLIC_SPOT_FALLBACK=0
# MSTOCK_APP_NAME=nifty_stat

# Background refresh for socket ticks (ms). UI also calls GET /api/nifty-spot each poll.
# NIFTY_INDEX_POLL_MS=8000

# Optional: simulate broker WebSocket drop/recovery (milliseconds between simulated drops).
# SIMULATE_FEED_DROP_MS=90000

# Frontend: leave empty in dev to use Vite proxy (same origin) for /api and /socket.io.
# For preview/production when UI is not behind the same host as the API:
# VITE_NIFTYOPTIMA_API=http://localhost:3200

# Mock feed tick interval (ms)
# FEED_TICK_MS=700

# After wiring @mstock-mirae-asset/nodetradingapi-typea + MConnect:
# MSTOCK_USE_SDK=true
